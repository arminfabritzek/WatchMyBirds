# Python bytecode
__pycache__/
*.pyc
*.pyo
*.pyd

# Runtime data (not needed in image)
output/
data/
models/
ingest/
ignore/
tmp/
*.log


# Node.js (Analytics frontend)
analytics/node_modules/
analytics/dist/

# Git metadata
.git

# Secrets
.env
.env.*

# System files
.DS_Store
Thumbs.db

# Large data files
*.csv
nas_file_index.csv
raw_input_index.csv

# IDE & Tools
.idea/
.vscode/
*.swp
*.swo

# Agent governance (internal)
AGENTS.md

# Docker files (not needed inside image)
docker-compose*.yml

# Unrelated project folders
rpi/
debuglogs/
docs/
private_docs/
.github/
.venv/
systemd/
tests/
# scripts/ stays mostly out of the container. The runtime code path for
# regenerating model_metadata.json lives in utils/model_metadata_generator;
# scripts/generate_model_metadata.py is only a thin CLI wrapper used by
# the deploy script on the build host.
#
# Exception: scripts/aesthetic_tag_nightly.py is the worker invoked by
# web/services/aesthetic_tag_scheduler.py inside the running app process,
# so it must live in the image. See .dockerignore syntax: leading "!" means
# "do not exclude". Order matters; this rule must follow the broad exclude.
scripts/
!scripts/aesthetic_tag_nightly.py

# Go2RTC config (credentials; not used in container image)
go2rtc.yaml
